<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E17"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify Connection"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="6-Digit Trust Code"
        android:textColor="#8892A4"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvTrustCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="582731"
        android:textColor="#6366F1"
        android:textSize="48sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirm this code matches the desktop."
        android:textColor="#8892A4"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Code expires in 2:00"
        android:textColor="#EF4444"
        android:textSize="12sp"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etCode"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:background="#141927"
        android:textColor="#FFFFFF"
        android:textColorHint="#6B7280"
        android:hint="Enter code"
        android:gravity="center"
        android:textSize="24sp"
        android:letterSpacing="0.2"
        android:inputType="number"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#8892A4"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#EF4444"
            android:backgroundTint="#1F1520"
            android:layout_marginEnd="12dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerify"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Verify"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6366F1"/>
    </LinearLayout>
</LinearLayout>
