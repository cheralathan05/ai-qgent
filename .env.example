# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=apa_user
DB_PASSWORD=changeme
DB_NAME=apa_os

# ADB Configuration
ADB_PATH=/usr/bin/adb

# Ollama Configuration
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama2

# Security Configuration
ENCRYPTION_KEY_PATH=/etc/apa_os/encryption.key
VAULT_SERVICE=aws_secrets
VAULT_ENDPOINT=https://secrets.aws.amazonaws.com

# Timeout Configuration (seconds)
INTENT_TIMEOUT=5
PLANNING_TIMEOUT=10
EXECUTION_TIMEOUT=60

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_FILE=apa_os.log

# Environment
ENVIRONMENT=development
